        "jsonOutput": "={\n  \"success\": true,\n  \"contactId\": \"{{ $('Merge - Normalize Contact ID').item.json.contactId }}\",\n  \"dealId\": \"{{ $('HubSpot - Create Deal').item.json.id }}\",\n  \"supabaseUpdated\": true,\n  \"timestamp\": \"{{ new Date().toISOString() }}\"\n}",
        "options": {}
