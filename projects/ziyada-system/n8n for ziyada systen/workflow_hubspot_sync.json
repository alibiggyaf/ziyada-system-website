        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"properties\": {\n    \"firstname\": \"{{ $('Set - Map to HubSpot Fields').item.json.firstname }}\",\n    \"lastname\": \"{{ $('Set - Map to HubSpot Fields').item.json.lastname }}\",\n    \"phone\": \"{{ $('Set - Map to HubSpot Fields').item.json.phone }}\",\n    \"company\": \"{{ $('Set - Map to HubSpot Fields').item.json.company }}\",\n    \"hs_lead_status\": \"{{ $('Set - Map to HubSpot Fields').item.json.hs_lead_status }}\",\n    \"industry\": \"{{ $('Set - Map to HubSpot Fields').item.json.industry }}\"\n  }\n}",
