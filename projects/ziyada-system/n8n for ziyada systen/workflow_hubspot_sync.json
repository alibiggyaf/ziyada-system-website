        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"properties\": {\n    \"dealname\": \"{{ $json.company || $json.firstname + ' ' + $json.lastname }} — {{ $json.services_requested || 'New Lead' }}\",\n    \"pipeline\": \"default\",\n    \"dealstage\": \"appointmentscheduled\",\n    \"amount\": \"{{ $json.budget || '' }}\",\n    \"closedate\": \"{{ $json.timeline || '' }}\",\n    \"description\": \"Source: {{ $json.source || 'website' }}\\nPage: {{ $json.source_page || '' }}\\nServices: {{ $json.services_requested || '' }}\"\n  }\n}",
        "options": {
          "timeout": 15000
        }
      },
